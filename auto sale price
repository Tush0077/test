File:

app/Filament/Pages/ProfitLoss.php

Replace code with:

namespace App\Filament\Pages;

use Filament\Pages\Page;
use App\Models\Sale;
use Illuminate\Support\Facades\DB;

class ProfitLoss extends Page
{
    protected static ?string $navigationIcon = 'heroicon-o-chart-bar';

    protected static string $view = 'filament.pages.profit-loss';

    public $startDate;
    public $endDate;

    public $totalSales = 0;
    public $totalCost = 0;
    public $profit = 0;

    public function generateReport()
    {

        $sales = Sale::whereBetween('created_at',[$this->startDate,$this->endDate])->sum('total_price');

        $cost = Sale::join('items','sales.item_id','=','items.id')
            ->whereBetween('sales.created_at',[$this->startDate,$this->endDate])
            ->sum(DB::raw('items.cost_price * sales.quantity'));

        $this->totalSales = $sales;

        $this->totalCost = $cost;

        $this->profit = $sales - $cost;

    }
}
