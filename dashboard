1️⃣ Sales Chart on Dashboard

Create chart widget:

php artisan make:filament-widget SalesChart --chart

Open:

app/Filament/Widgets/SalesChart.php

Replace with:

namespace App\Filament\Widgets;

use Filament\Widgets\ChartWidget;
use App\Models\Sale;

class SalesChart extends ChartWidget
{
    protected static ?string $heading = 'Sales Overview';

    protected function getData(): array
    {
        $sales = Sale::selectRaw('DATE(created_at) as date, SUM(total_price) as total')
            ->groupBy('date')
            ->orderBy('date')
            ->limit(7)
            ->get();

        return [
            'datasets' => [
                [
                    'label' => 'Sales',
                    'data' => $sales->pluck('total'),
                ],
            ],
            'labels' => $sales->pluck('date'),
        ];
    }

    protected function getType(): string
    {
        return 'line';
    }
}

Now dashboard will show sales trend graph.

2️⃣ Top Selling Items Widget

Create widget:

php artisan make:filament-widget TopItems

Open:

app/Filament/Widgets/TopItems.php

Code:

namespace App\Filament\Widgets;

use Filament\Widgets\TableWidget as BaseWidget;
use Filament\Tables;
use App\Models\Sale;
use Illuminate\Support\Facades\DB;

class TopItems extends BaseWidget
{
    protected function getTableQuery()
    {
        return Sale::select(
            'items.name',
            DB::raw('SUM(quantity) as total_sold')
        )
        ->join('items','sales.item_id','=','items.id')
        ->groupBy('items.name')
        ->orderByDesc('total_sold')
        ->limit(5);
    }

    protected function getTableColumns(): array
    {
        return [

Tables\Columns\TextColumn::make('name')
->label('Item'),

Tables\Columns\TextColumn::make('total_sold')
->label('Total Sold'),

        ];
    }
}

Now dashboard shows:

Top Selling Items
Item Name | Total Sold

Managers love this feature.

3️⃣ Monthly Revenue Graph

Create widget:

php artisan make:filament-widget MonthlyRevenue --chart

Open:

app/Filament/Widgets/MonthlyRevenue.php

Code:

namespace App\Filament\Widgets;

use Filament\Widgets\ChartWidget;
use App\Models\Sale;

class MonthlyRevenue extends ChartWidget
{
    protected static ?string $heading = 'Monthly Revenue';

    protected function getData(): array
    {
        $data = Sale::selectRaw('MONTH(created_at) as month, SUM(total_price) as total')
            ->groupBy('month')
            ->orderBy('month')
            ->get();

        return [
            'datasets' => [
                [
                    'label' => 'Revenue',
                    'data' => $data->pluck('total'),
                ],
            ],
            'labels' => $data->pluck('month'),
        ];
    }

    protected function getType(): string
    {
        return 'bar';
    }
}

Now dashboard will show monthly revenue bar chart.

